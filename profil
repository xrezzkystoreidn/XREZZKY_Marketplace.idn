async function saveProfile() {
  const payload = {
    username:          document.getElementById('eu')?.value.trim(),
    full_name:         document.getElementById('efn')?.value.trim(),
    whatsapp:          document.getElementById('ewa')?.value.trim(),
    location:          document.getElementById('eloc')?.value.trim(),
    website:           document.getElementById('eweb')?.value.trim(),
    store_name:        document.getElementById('esn')?.value.trim(),
    store_description: document.getElementById('esd')?.value.trim(),
    store_category:    document.getElementById('esc')?.value,
    store_hours:       document.getElementById('ehs')?.value.trim(),
    telegram:          document.getElementById('etg')?.value.trim(),
    instagram:         document.getElementById('eig')?.value.trim(),
    twitter:           document.getElementById('etw')?.value.trim(),
    discord:           document.getElementById('edi')?.value.trim(),
  };
  if (!payload.username) return toast('Username wajib diisi', 'e');
  const { error } = await sb.from('profiles').update(payload).eq('id', cUser.id);
  if (error) return toast('Gagal: '+error.message, 'e');
  Object.assign(cProfile, payload);
  buildHeader();
  buildInfoList();
  buildQuickLinks();
  toast('Profil diperbarui ✅', 's');
  switchTab('overview');
}

// ── SECURITY ──
function showSecurityEmail() {
  const el = document.getElementById('acEmail');
  if (el) el.value = cUser.email;
}

async function changePass() {
  const p1 = document.getElementById('p1')?.value;
  const p2 = document.getElementById('p2')?.value;
  if (!p1||!p2) return toast('Isi kedua field', 'e');
  if (p1!==p2)  return toast('Password tidak cocok', 'e');
  if (p1.length<6) return toast('Min. 6 karakter', 'e');
  const { error } = await sb.auth.updateUser({ password: p1 });
  if (error) return toast('Gagal: '+error.message, 'e');
  toast('Password berhasil diperbarui ✅', 's');
  document.getElementById('p1').value='';
  document.getElementById('p2').value='';
}

