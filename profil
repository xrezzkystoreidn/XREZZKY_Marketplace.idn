<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
// ═══ CONFIG ═══
const SUPA_URL  = 'https://jydfjfjttpmropoczgop.supabase.co';
const SUPA_KEY  = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp5ZGZqZmp0dHBtcm9wb2N6Z29wIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgxMDgyNTEsImV4cCI6MjA5MzY4NDI1MX0.CyxQU-zng4OBP1kOlZEn0UZVGurfVp6TfNWS_zOaf3s';
const CLD_CLOUD  = 'drjmclzbi';
const CLD_PRESET = 'xrezzky_unsigned';
const CLD_BASE   = `https://res.cloudinary.com/${CLD_CLOUD}/image/upload/`;
const CLD_UP     = `https://api.cloudinary.com/v1_1/${CLD_CLOUD}/image/upload`;

const sb = supabase.createClient(SUPA_URL, SUPA_KEY);

// ═══ STATE ═══
let cUser    = null;  // supabase auth user
let cProfile = null;  // profiles row
let myOrders = [];
let myProds  = [];
let activeTab = 'overview';

// ═══ INIT ═══
document.addEventListener('DOMContentLoaded', async () => {
  document.body.style.opacity = '0';
  document.body.style.transition = 'opacity .22s ease';

  const { data: { session } } = await sb.auth.getSession();

  if (!session) {
    // Show guest wall — must register/login to view profile
    document.getElementById('guestWall').style.display = 'flex';
    requestAnimationFrame(() => document.body.style.opacity = '1');
    return;
  }

  cUser = session.user;
  await loadProfile();
  await Promise.all([loadOrders(), loadProducts()]);

  buildPage();
  document.getElementById('mainContent').style.display = 'block';
  document.body.classList.add('is-own');
  requestAnimationFrame(() => document.body.style.opacity = '1');

  // Update XBN avatar
  updateXbnAv();
});

// ═══ LOAD DATA ═══
async function loadProfile() {
  const { data } = await sb.from('profiles').select('*').eq('id', cUser.id).maybeSingle();
  cProfile = data || { id: cUser.id, username: cUser.email.split('@')[0], email: cUser.email, role: 'buyer', balance: 0 };
}

async function loadOrders() {
  const { data } = await sb.from('orders').select('*, products(name, price, image_url, category)').eq('buyer_id', cUser.id).order('created_at', { ascending: false }).limit(20);
  myOrders = data || [];
}

async function loadProducts() {
  if (!cProfile || !['seller','admin'].includes(cProfile.role)) return;
  const { data } = await sb.from('products').select('*').eq('seller_id', cUser.id).order('created_at', { ascending: false });
  myProds = data || [];
}

