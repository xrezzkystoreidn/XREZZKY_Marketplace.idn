<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>XREZZKY — Profil</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f1115;--nav:#171c24;--surface:#1d2430;--border:#2a3442;
  --accent:#4a7dff;--ah:#5d8fff;--txt:#f5f7fa;--txt2:#9ba6b2;
  --success:#22c55e;--warn:#f59e0b;--danger:#ef4444;
  --purple:#a855f7;--cyan:#06b6d4;
  --r:14px;--rsm:9px;
}
html{scroll-behavior:smooth}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:200;background:rgba(23,28,36,.94);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);height:56px;display:flex;align-items:center;padding:0 18px;gap:12px}
.tb-brand{display:flex;align-items:center;gap:7px;text-decoration:none;color:var(--txt);font-family:'Syne',sans-serif;font-size:15px;font-weight:800}
.tb-dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
.tb-brand span{color:var(--accent)}
.tb-back{width:34px;height:34px;border-radius:50%;background:var(--surface);border:1px solid var(--border);color:var(--txt2);font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .18s;flex-shrink:0}
.tb-back:hover{border-color:var(--accent);color:var(--accent)}
.tb-sp{flex:1}
.tb-acts{display:flex;gap:8px;align-items:center}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--rsm);font-family:'Poppins',sans-serif;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all .18s;text-decoration:none}
.bp{background:var(--accent);color:#fff}.bp:hover{background:var(--ah)}
.bg{background:transparent;color:var(--txt2);border:1px solid var(--border)}.bg:hover{color:var(--txt);border-color:var(--txt2)}
.bd{background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.2)}
.bsm{padding:6px 12px;font-size:12px}
.bxs{padding:4px 9px;font-size:11px}

/* ── PAGE WRAP ── */
.page-wrap{max-width:1100px;margin:0 auto;padding:24px 20px 100px}

/* ── GUEST WALL ── */
#guestWall{display:none;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;gap:20px;text-align:center;padding:40px 20px}
#guestWall .gw-icon{font-size:56px;opacity:.25}
#guestWall h2{font-size:22px;font-weight:700;font-family:'Syne',sans-serif}
#guestWall p{font-size:14px;color:var(--txt2);max-width:360px;line-height:1.6}
.gw-btns{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}

/* ── PROFILE HEADER ── */
.prof-header{background:var(--nav);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:20px}
.banner{height:160px;background:linear-gradient(135deg,#0f1a2e,#1a2540,#0d1520);position:relative;overflow:hidden}
.banner img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
.banner-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(23,28,36,.9) 100%)}
.banner-deco{position:absolute;inset:0;pointer-events:none}
.bd-c{position:absolute;border-radius:50%;border:1px solid rgba(74,125,255,.1)}
.bdc1{width:260px;height:260px;top:-80px;right:60px}
.bdc2{width:140px;height:140px;top:10px;right:180px;border-color:rgba(168,85,247,.08)}
.bdc3{width:80px;height:80px;bottom:10px;left:100px;border-color:rgba(6,182,212,.08)}
.banner-edit-btn{position:absolute;top:12px;right:12px;background:rgba(15,17,21,.7);border:1px solid rgba(255,255,255,.15);color:var(--txt2);font-size:12px;padding:6px 12px;border-radius:var(--rsm);cursor:pointer;font-family:'Poppins',sans-serif;display:none;align-items:center;gap:6px;backdrop-filter:blur(6px);transition:all .18s}
.banner-edit-btn:hover{color:var(--txt)}
.is-own .banner-edit-btn{display:flex}

/* Identity strip */
.identity{padding:0 22px 18px;margin-top:-50px;position:relative;display:flex;align-items:flex-end;gap:16px;flex-wrap:wrap}
.av-ring{width:96px;height:96px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--purple));padding:3px;flex-shrink:0;position:relative}
.av-inner{width:100%;height:100%;border-radius:50%;background:var(--bg);overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--accent)}
.av-inner img{width:100%;height:100%;object-fit:cover}
.av-edit{position:absolute;bottom:2px;right:2px;width:26px;height:26px;border-radius:50%;background:var(--accent);color:#fff;font-size:11px;display:none;align-items:center;justify-content:center;cursor:pointer;border:2px solid var(--bg);transition:background .18s}
.av-edit:hover{background:var(--ah)}
.is-own .av-edit{display:flex}
.av-progress{position:absolute;bottom:-8px;left:0;right:0;height:3px;background:var(--border);border-radius:2px;overflow:hidden;display:none}
.av-progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .3s}

.ident-info{flex:1;padding-bottom:10px;min-width:0}
.ident-name{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.vi-icon{color:var(--accent);font-size:15px;display:none}
.ident-handle{font-size:13px;color:var(--txt2);margin-top:2px}
.ident-badges{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.ib{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:.02em}
.ib-admin{background:rgba(239,68,68,.12);color:var(--danger);border:1px solid rgba(239,68,68,.2)}
.ib-seller{background:rgba(245,158,11,.12);color:var(--warn);border:1px solid rgba(245,158,11,.2)}
.ib-cs{background:rgba(6,182,212,.12);color:var(--cyan);border:1px solid rgba(6,182,212,.2)}
.ib-buyer{background:rgba(74,125,255,.12);color:var(--accent);border:1px solid rgba(74,125,255,.2)}
.ib-verified{background:rgba(74,125,255,.1);color:var(--accent);border:1px solid rgba(74,125,255,.2)}

.ident-acts{padding-bottom:10px;display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;flex-shrink:0}

/* Stats bar */
.stats-bar{display:flex;border-top:1px solid var(--border);overflow-x:auto}
.stats-bar::-webkit-scrollbar{display:none}
.sb-item{flex:1;min-width:80px;padding:14px 10px;text-align:center;cursor:pointer;border-bottom:2px solid transparent;transition:all .18s;flex-shrink:0}
.sb-item:hover{background:var(--surface)}
.sb-val{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;line-height:1}
.sb-lab{font-size:10px;color:var(--txt2);font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-top:3px}

/* ── CONTENT GRID ── */
.content-grid{display:grid;grid-template-columns:280px 1fr;gap:18px}

/* ── PANEL CARD ── */
.panel{background:var(--nav);border:1px solid var(--border);border-radius:var(--r);margin-bottom:14px;overflow:hidden}
.panel-head{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.panel-title{font-size:12px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.07em}
.panel-body{padding:16px 18px}

/* ── BALANCE CARD ── */
.balance-card{background:linear-gradient(135deg,rgba(74,125,255,.15),rgba(124,58,237,.1));border:1px solid rgba(74,125,255,.2);border-radius:var(--r);padding:18px;margin-bottom:14px;position:relative;overflow:hidden}
.balance-card::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;background:radial-gradient(circle,rgba(74,125,255,.12),transparent 70%);border-radius:50%;pointer-events:none}
.bc-label{font-size:11px;color:var(--txt2);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.bc-amount{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--txt);line-height:1.1}
.bc-sub{font-size:11px;color:var(--txt2);margin-top:4px}
.bc-actions{display:flex;gap:8px;margin-top:14px}
.bc-btn{flex:1;padding:9px 0;border-radius:var(--rsm);font-family:'Poppins',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .18s;display:flex;align-items:center;justify-content:center;gap:5px}
.bc-dep{background:var(--accent);color:#fff}.bc-dep:hover{background:var(--ah)}
.bc-his{background:var(--surface);color:var(--txt2);border:1px solid var(--border)}.bc-his:hover{color:var(--txt);border-color:var(--txt2)}

/* Info list */
.info-list{display:flex;flex-direction:column;gap:9px}
.info-row{display:flex;align-items:center;gap:9px;font-size:12px;color:var(--txt2)}
.info-row i{width:14px;text-align:center;color:var(--accent);font-size:12px;flex-shrink:0}
.info-row a{color:var(--accent);text-decoration:none}
.info-row a:hover{text-decoration:underline}

/* Quick links */
.quick-links{display:flex;flex-direction:column;gap:6px}
.ql-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--rsm);font-size:13px;font-weight:500;color:var(--txt2);cursor:pointer;transition:all .18s;text-decoration:none;border:none;background:none;width:100%;text-align:left}
.ql-item:hover,.ql-item.active{background:var(--surface);color:var(--txt)}
.ql-item i{width:16px;text-align:center;font-size:13px}
.ql-sep{height:1px;background:var(--border);margin:6px 0}
.ql-danger{color:var(--danger)!important}.ql-danger:hover{background:rgba(239,68,68,.08)!important}

/* Role badge on quick link */
.ql-rbadge{margin-left:auto;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase}

/* ── RIGHT COLUMN: TABS ── */
.tab-bar{display:flex;background:var(--nav);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:16px;overflow-x:auto}
.tab-bar::-webkit-scrollbar{display:none}
.tab-btn{padding:11px 18px;font-size:12px;font-weight:500;color:var(--txt2);cursor:pointer;border:none;background:none;font-family:'Poppins',sans-serif;transition:all .18s;white-space:nowrap;flex-shrink:0;display:flex;align-items:center;gap:6px;border-bottom:2px solid transparent}
.tab-btn:hover{background:var(--surface);color:var(--txt)}
.tab-btn.active{background:var(--surface);color:var(--txt);border-bottom-color:var(--accent)}
.tab-btn .tc{background:var(--accent);color:#fff;font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px;min-width:16px;text-align:center}
.tab-panel{display:none}.tab-panel.active{display:block}

/* Overview panel */
.overview-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.ov-card{background:var(--nav);border:1px solid var(--border);border-radius:var(--rsm);padding:16px}
.ov-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:10px}
.ov-val{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;line-height:1}
.ov-lab{font-size:11px;color:var(--txt2);margin-top:3px}

/* Products grid */
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px}
.prod-card{background:var(--nav);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:all .22s}
.prod-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.pc-img{width:100%;aspect-ratio:16/9;background:var(--surface);overflow:hidden;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:22px}
.pc-img img{width:100%;height:100%;object-fit:cover}
.pc-body{padding:11px 13px}
.pc-cat{font-size:10px;font-weight:600;color:var(--accent);background:rgba(74,125,255,.1);padding:2px 7px;border-radius:4px;display:inline-block;margin-bottom:4px}
.pc-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pc-price{font-size:14px;font-weight:700;color:var(--accent);margin-top:4px}

/* Activity */
.act-list{display:flex;flex-direction:column;gap:0}
.act-item{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
.act-item:last-child{border-bottom:none}
.act-icon{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px}
.act-txt{font-size:13px;line-height:1.5}
.act-txt strong{color:var(--txt)}
.act-time{font-size:11px;color:var(--txt2);margin-top:2px}

/* Empty state */
.empty{text-align:center;padding:48px 20px;color:var(--txt2)}
.empty i{font-size:34px;display:block;margin-bottom:12px;opacity:.3}
.empty p{font-size:13px}

/* Security panel */
.sec-section{padding:18px 0;border-bottom:1px solid var(--border)}
.sec-section:last-child{border-bottom:none}
.sec-section-title{font-size:13px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.fg{margin-bottom:13px}
.fg label{display:block;font-size:12px;color:var(--txt2);margin-bottom:5px;font-weight:500}
.fg input,.fg textarea,.fg select{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:var(--rsm);padding:9px 12px;color:var(--txt);font-family:'Poppins',sans-serif;font-size:13px;outline:none;transition:border .18s}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--accent)}
.fg input::placeholder{color:var(--txt2);opacity:.5}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg-note{font-size:11px;color:var(--txt2);margin-top:4px}

/* Pin input */
.pin-wrap{display:flex;gap:10px;justify-content:center}
.pin-dig{width:48px;height:56px;background:var(--surface);border:1px solid var(--border);border-radius:var(--rsm);color:var(--txt);font-size:20px;font-weight:700;text-align:center;outline:none;transition:border .18s}
.pin-dig:focus{border-color:var(--accent)}

/* Danger zone */
.danger-zone{background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.15);border-radius:var(--rsm);padding:14px 16px;margin-top:14px}
.dz-title{font-size:12px;font-weight:600;color:var(--danger);margin-bottom:10px}

/* ── ROLE-SPECIFIC DASHBOARDS ── */
/* Seller stats */
.seller-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.ss-card{background:var(--nav);border:1px solid var(--border);border-radius:var(--rsm);padding:16px;text-align:center}
.ss-val{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;line-height:1}
.ss-lab{font-size:11px;color:var(--txt2);margin-top:4px}

/* CS card */
.cs-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.cs-card{background:var(--nav);border:1px solid var(--border);border-radius:var(--rsm);padding:14px}
.cs-val{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;line-height:1}
.cs-lab{font-size:11px;color:var(--txt2);margin-top:3px}

/* Chip badge */
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600}
.chip-g{background:rgba(34,197,94,.12);color:var(--success);border:1px solid rgba(34,197,94,.2)}
.chip-y{background:rgba(245,158,11,.12);color:var(--warn);border:1px solid rgba(245,158,11,.2)}
.chip-r{background:rgba(239,68,68,.12);color:var(--danger);border:1px solid rgba(239,68,68,.2)}

/* ── MODALS ── */
.mo{position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.75);display:none;align-items:center;justify-content:center;padding:20px}
.mo.open{display:flex}
.mb{background:var(--nav);border:1px solid var(--border);border-radius:var(--r);width:100%;animation:fup .3s ease;overflow:hidden}
@keyframes fup{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
.mh{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.mh h3{font-size:16px;font-weight:700;font-family:'Syne',sans-serif}
.mbody{padding:20px;overflow-y:auto;max-height:78vh}
.mbody::-webkit-scrollbar{width:4px}
.mfoot{padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px}
.mc{background:none;border:none;color:var(--txt2);font-size:18px;cursor:pointer}
.mc:hover{color:var(--txt)}

/* Upload bar */
.upload-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;display:none;margin:8px 0}
.upload-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .3s}

/* Char count */
.char-count{font-size:11px;color:var(--txt2);text-align:right;margin-top:3px}

/* ── TOAST ── */
#tc{position:fixed;bottom:80px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:8px}
@media(min-width:901px){#tc{bottom:20px;right:20px}}
.toast{background:var(--nav);border:1px solid var(--border);border-left:3px solid var(--accent);color:var(--txt);font-size:13px;padding:10px 16px;border-radius:var(--rsm);min-width:240px;animation:sli .3s ease}
.toast.s{border-left-color:var(--success)}.toast.e{border-left-color:var(--danger)}.toast.w{border-left-color:var(--warn)}
@keyframes sli{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}

/* ── SPINNER ── */
.sp{width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spn .7s linear infinite;margin:0 auto}
@keyframes spn{to{transform:rotate(360deg)}}
.lc{display:flex;align-items:center;justify-content:center;padding:48px}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .content-grid{grid-template-columns:1fr}
  .left-col-wrap{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  #topbar{display:none!important}
  #mobileHdr{display:flex!important}
  #xbn{display:flex!important}
  .page-wrap{padding:14px 12px 90px}
  .overview-grid{grid-template-columns:1fr 1fr}
  .seller-stats{grid-template-columns:1fr 1fr}
  .mo{padding:0;align-items:flex-end}
  .mb{border-radius:20px 20px 0 0}
  .mbody{max-height:75vh}
}
@media(max-width:600px){
  .identity{flex-direction:column;align-items:flex-start;margin-top:-38px;gap:10px}
  .ident-acts{width:100%}
  .av-ring{width:80px;height:80px}
  .av-inner{font-size:26px}
  .ident-name{font-size:19px}
  .left-col-wrap{grid-template-columns:1fr}
  .overview-grid{grid-template-columns:1fr 1fr}
  .seller-stats{grid-template-columns:1fr}
  .fg2{grid-template-columns:1fr}
  .banner{height:140px}
}
@media(max-width:380px){
  .overview-grid{grid-template-columns:1fr}
  .bc-actions{flex-direction:column}
}
@media(min-width:901px){
  #xbn{display:none!important}
  #mobileHdr{display:none!important}
  #topbar{display:flex!important}
}

/* Mobile header */
#mobileHdr{display:none;position:sticky;top:0;z-index:300;background:var(--nav);border-bottom:1px solid var(--border);height:52px;align-items:center;padding:0 14px;gap:12px}
.mhb{width:34px;height:34px;border-radius:50%;background:var(--surface);border:1px solid var(--border);color:var(--txt2);font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.mhb:active{transform:scale(.9)}
.mh-title{font-size:15px;font-weight:700;flex:1}
.mh-logo{font-size:11px;font-weight:700;color:var(--accent);opacity:.7;font-family:'Syne',sans-serif}

/* Bottom Nav */
#xbn{display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:rgba(23,28,36,.97);backdrop-filter:blur(20px);border-top:1px solid rgba(74,125,255,.18);height:64px;padding:0 8px;padding-bottom:env(safe-area-inset-bottom,0px);box-shadow:0 -4px 24px rgba(0,0,0,.5)}
.xbn-inner{display:flex;align-items:center;width:100%;height:100%}
.xbn-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;cursor:pointer;color:#6b7a8d;font-family:'Poppins',sans-serif;padding:4px 0;position:relative;overflow:hidden;transition:color .2s;border-radius:12px;min-height:52px;text-decoration:none;-webkit-tap-highlight-color:transparent}
.xbn-btn i{font-size:20px;line-height:1;transition:transform .25s cubic-bezier(.34,1.56,.64,1),color .2s;display:block}
.xbn-btn span{font-size:10px;font-weight:600;letter-spacing:.02em;line-height:1}
.xbn-btn.active{color:var(--accent)}.xbn-btn.active i{transform:translateY(-2px) scale(1.15);color:var(--accent)}
.xbn-btn::after{content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%);width:0;height:3px;border-radius:2px;background:linear-gradient(90deg,var(--accent),#7c3aed);transition:width .25s cubic-bezier(.34,1.56,.64,1)}
.xbn-btn.active::after{width:24px}
.xbn-btn:active{transform:scale(.88)}
.xbn-fab-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding-bottom:6px;gap:2px}
.xbn-fab{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#4a7dff,#7c3aed);color:#fff;font-size:22px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(74,125,255,.55);-webkit-tap-highlight-color:transparent;transition:transform .2s cubic-bezier(.34,1.56,.64,1)}
.xbn-fab:active{transform:scale(.85)}
.xbn-fab-label{font-size:10px;font-weight:600;color:var(--txt2)}
.xbn-av{width:26px;height:26px;border-radius:50%;background:var(--surface);border:2px solid transparent;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#6b7a8d;transition:border-color .2s}
.xbn-av img{width:100%;height:100%;object-fit:cover}
.xbn-btn.active .xbn-av{border-color:var(--accent)}
</style>
