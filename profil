// ── UTILS ──
function fmtRp(v) { if (!v&&v!==0) return 'Rp 0'; return 'Rp '+Number(v).toLocaleString('id-ID'); }
function fmtDate(d) { if (!d) return '—'; return new Date(d).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}); }
function timeAgo(d) {
  if (!d) return '—';
  const s = Math.floor((Date.now()-new Date(d))/1000);
  if (s<60) return 'baru saja';
  if (s<3600) return Math.floor(s/60)+' mnt lalu';
  if (s<86400) return Math.floor(s/3600)+' jam lalu';
  if (s<2592000) return Math.floor(s/86400)+' hari lalu';
  return fmtDate(d);
}
function esc(s) { if(!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function animVal(id, num, str) {
  const el = document.getElementById(id); if (!el) return;
  if (str !== undefined) { el.textContent = str; return; }
  const steps=20; let i=0;
  const iv=setInterval(()=>{ i++; el.textContent=Math.round(num*(i/steps)).toLocaleString('id-ID'); if(i>=steps){clearInterval(iv);el.textContent=num.toLocaleString('id-ID');}},500/steps);
}
function toast(msg, type='') {
  const el=document.createElement('div'); el.className=`toast ${type}`; el.textContent=msg;
  document.getElementById('tc').appendChild(el);
  setTimeout(()=>el.remove(), 3500);
}

