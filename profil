async function loadAdminStats() {
  try {
    const [u, p, o] = await Promise.all([
      sb.from('profiles').select('*',{count:'exact',head:true}),
      sb.from('products').select('*',{count:'exact',head:true}).eq('is_active',true),
      sb.from('orders').select('*',{count:'exact',head:true}),
    ]);
    const cards = document.querySelectorAll('#adminCards .ov-val');
    if (cards[0]) cards[0].textContent = (u.count||0).toLocaleString('id-ID');
    if (cards[1]) cards[1].textContent = (p.count||0).toLocaleString('id-ID');
    if (cards[3]) cards[3].textContent = (o.count||0).toLocaleString('id-ID');
  } catch(e) {}
}

