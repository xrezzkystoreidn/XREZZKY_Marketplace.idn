function updatePinStatus() {
  const el = document.getElementById('pinStatus');
  if (!el) return;
  const hasPin = cProfile?.transaction_pin;
  el.innerHTML = hasPin
    ? `<span style="color:var(--success);font-weight:600"><i class="fas fa-circle-check"></i> PIN aktif</span>`
    : `<span style="color:var(--warn);font-weight:600"><i class="fas fa-triangle-exclamation"></i> Belum ada PIN — wajib dibuat sebelum transaksi</span>`;
}

function pinNext(i) {
  const v = document.getElementById(`pin${i}`).value;
  if (v && i < 5) document.getElementById(`pin${i+1}`).focus();
}
function pinBack(i, e) {
  if (e.key==='Backspace' && !document.getElementById(`pin${i}`).value && i>0) {
    document.getElementById(`pin${i-1}`).focus();
  }
}
function cpinNext(i) {
  const v = document.getElementById(`cpin${i}`).value;
  if (v && i < 5) document.getElementById(`cpin${i+1}`).focus();
}
function cpinBack(i, e) {
  if (e.key==='Backspace' && !document.getElementById(`cpin${i}`).value && i>0) {
    document.getElementById(`cpin${i-1}`).focus();
  }
}

async function savePin() {
  const pin  = [0,1,2,3,4,5].map(i=>document.getElementById(`pin${i}`)?.value||'').join('');
  const cpin = [0,1,2,3,4,5].map(i=>document.getElementById(`cpin${i}`)?.value||'').join('');
  if (pin.length!==6 || !/^\d{6}$/.test(pin)) return toast('PIN harus 6 digit angka', 'e');
  if (pin!==cpin) return toast('PIN tidak cocok', 'e');
  // Store as hash (simple base64 for demo; in prod use bcrypt via edge function)
  const pinHash = btoa(pin);
  const { error } = await sb.from('profiles').update({ transaction_pin: pinHash }).eq('id', cUser.id);
  if (error) return toast('Gagal: '+error.message, 'e');
  cProfile.transaction_pin = pinHash;
  // Clear inputs
  for (let i=0;i<6;i++) { document.getElementById(`pin${i}`).value=''; document.getElementById(`cpin${i}`).value=''; }
  updatePinStatus();
  buildBalance();
  toast('PIN transaksi disimpan ✅', 's');
}

// ── BIO ──
function openBioEdit() {
  document.getElementById('bioText').style.display = 'none';
  const ea = document.getElementById('bioEditArea');
  ea.style.display = 'block';
  const inp = document.getElementById('bioInp');
  inp.value = cProfile.bio || '';
  document.getElementById('bioCc').textContent = inp.value.length+'/200';
  inp.focus();
}
function cancelBio() {
  document.getElementById('bioText').style.display = 'block';
  document.getElementById('bioEditArea').style.display = 'none';
}
async function saveBio() {
  const bio = document.getElementById('bioInp').value.trim();
  const { error } = await sb.from('profiles').update({ bio }).eq('id', cUser.id);
  if (error) return toast('Gagal: '+error.message, 'e');
  cProfile.bio = bio;
  const el = document.getElementById('bioText');
  el.innerHTML = bio ? esc(bio) : '<span style="font-style:italic;opacity:.5">Belum ada bio.</span>';
  cancelBio();
  toast('Bio diperbarui ✅', 's');
}

// ── AVATAR UPLOAD ──
async function uploadAvatar(event) {
  const file = event.target.files[0]; if (!file) return;
  if (file.size > 3*1024*1024) return toast('Maks 3MB', 'e');
  const bar = document.getElementById('avBar'), fill = document.getElementById('avFill');
  bar.style.display='block'; fill.style.width='20%';
  try {
    const fd = new FormData(); fd.append('file',file); fd.append('upload_preset',CLD_PRESET); fd.append('folder','avatars');
    fill.style.width='60%';
    const res  = await fetch(CLD_UP, { method:'POST', body:fd });
    const data = await res.json();
    fill.style.width='100%';
    if (data.error) throw new Error(data.error.message);
    const rel = data.public_id+'.'+data.format;
    await sb.from('profiles').update({ avatar_url: rel }).eq('id', cUser.id);
    cProfile.avatar_url = rel;
    const img = `<img src="${data.secure_url}" alt="av"/>`;
    document.getElementById('mainAv').innerHTML = img;
    const ep = document.getElementById('editAvPrev');
    if (ep) ep.innerHTML = img;
    updateXbnAv();
    toast('Foto profil diperbarui ✅', 's');
  } catch(err) { toast('Upload gagal: '+err.message, 'e'); }
  finally { setTimeout(()=>{ bar.style.display='none'; fill.style.width='0%'; },800); event.target.value=''; }
}

function triggerBannerUpload() { document.getElementById('bannerFileInput').click(); }
async function uploadBanner(event) {
  const file = event.target.files[0]; if (!file) return;
  if (file.size > 5*1024*1024) return toast('Maks 5MB', 'e');
  try {
    const fd = new FormData(); fd.append('file',file); fd.append('upload_preset',CLD_PRESET); fd.append('folder','banners');
    toast('Mengupload banner...', 'w');
    const res  = await fetch(CLD_UP, { method:'POST', body:fd });
    const data = await res.json();
    if (data.error) throw new Error(data.error.message);
    const rel = data.public_id+'.'+data.format;
    await sb.from('profiles').update({ store_banner: rel }).eq('id', cUser.id);
    cProfile.store_banner = rel;
    const bw = document.getElementById('bannerWrap');
    let img = bw.querySelector('img:not([alt="banner-overlay"])');
    if (!img) { img = document.createElement('img'); img.style='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0'; bw.insertBefore(img,bw.firstChild); }
    img.src = data.secure_url;
    toast('Banner diperbarui ✅', 's');
  } catch(err) { toast('Gagal: '+err.message, 'e'); }
  event.target.value = '';
}

